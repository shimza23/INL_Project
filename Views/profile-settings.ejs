<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Profile Settings | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    .profile-layout { display: grid; grid-template-columns: 250px 1fr; gap: 18px; }
    .profile-sidebar-card { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius-lg); padding: 24px; text-align: center; }
    .profile-avatar { width: 72px; height: 72px; background: var(--turquoise-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px; margin: 0 auto 12px; }
    .modules-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; max-height: 200px; overflow-y: auto; padding: 10px; border: 1px solid var(--gray-200); border-radius: var(--radius-sm); }
    .module-checkbox { display: flex; align-items: center; gap: 8px; padding: 5px; }
  </style>
</head>
<body>
<div class="layout">
  <aside class="sidebar">
    <div class="sidebar-logo"><div class="logo-icon">🎓</div><div class="brand"><span class="brand-name">SmartTutor</span><span class="brand-sub">Belgium Campus iTversity</span></div></div>
    <nav class="sidebar-nav">
      <% if (user.role === 'student') { %>
        <a href="/student-dashboard" class="nav-item">📊 Dashboard</a>
        <a href="/my-bookings" class="nav-item">📅 My Bookings</a>
        <a href="/book-session" class="nav-item">🔍 Find a Tutor</a>
        <a href="/notifications" class="nav-item">🔔 Notifications</a>
        <a href="/profile-settings" class="nav-item active">👤 Profile</a>
      <% } else if (user.role === 'tutor') { %>
        <a href="/tutor-dashboard" class="nav-item">📅 My Schedule</a>
        <a href="/student-requests" class="nav-item">📋 Student Requests</a>
        <a href="/my-bookings" class="nav-item">📊 Sessions</a>
        <a href="/profile-settings" class="nav-item active">👤 Profile</a>
      <% } else { %>
        <a href="/admin-analytics" class="nav-item">📈 Analytics</a>
        <a href="/profile-settings" class="nav-item active">⚙️ Settings</a>
      <% } %>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
      <div><div class="user-name"><%= user.name %></div><div class="user-role"><%= user.role === 'student' ? 'Student' : user.role === 'tutor' ? 'Tutor' : 'Admin' %></div></div>
      <a href="/logout" class="logout-btn" style="margin-left: auto; color: var(--gray-400);">🚪 Logout</a>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <div class="topbar-left"><h1>Profile Settings</h1><p>Manage your profile</p></div>
      <div class="topbar-right"><a href="/profile-settings" class="user-avatar"><%= user.name.charAt(0) %></a><a href="/logout" class="btn btn-ghost btn-sm">Logout</a></div>
    </header>

    <div class="page-content">
      <div class="profile-layout">
        <div class="profile-sidebar-card">
          <div class="profile-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
          <div><strong><%= user.name %></strong></div>
          <div style="color:var(--gray-400);"><%= user.role === 'student' ? 'Student' : user.role === 'tutor' ? 'Tutor' : 'Admin' %></div>
          <div class="profile-stats" style="display:flex; justify-content:center; gap:20px; margin-top:12px;"><div><div class="pstat-val"><%= user.totalSessions || 0 %></div><div class="pstat-label">Sessions</div></div><div><div class="pstat-val"><%= user.rating || 0 %></div><div class="pstat-label">Rating</div></div></div>
        </div>
        <div class="card">
          <form method="POST" action="/profile-settings?_method=PUT">
            <div class="form-row"><div class="form-group"><label class="form-label">Full Name</label><input class="form-input" name="name" value="<%= user.name %>"></div><div class="form-group"><label class="form-label">Phone</label><input class="form-input" name="phone" value="<%= user.phone || '' %>"></div></div>
            <div class="form-group"><label class="form-label">Email</label><input class="form-input" value="<%= user.email %>" disabled></div>
            <% if (user.role === 'tutor') { %>
              <div class="form-group"><label class="form-label">Modules I Tutor</label><div class="modules-grid"><% subjects.forEach(subject => { %><label class="module-checkbox"><input type="checkbox" name="modules" value="<%= subject.code %>" <%= user.modules && user.modules.includes(subject.code) ? 'checked' : '' %>> <span><%= subject.code %> - <%= subject.name %></span></label><% }); %></div></div>
            <% } %>
            <div class="form-group"><label class="form-label">Bio</label><textarea class="form-input" name="bio" rows="4"><%= user.bio || '' %></textarea></div>
            <div class="form-actions"><a href="/<%= user.role %>-dashboard" class="btn btn-ghost">Cancel</a><button type="submit" class="btn btn-primary">Save Changes</button></div>
          </form>
        </div>
      </div>
    </div>
  </main>
</div>
</body>
</html>