<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Student Dashboard | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
</head>
<body>
<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">🎓</div>
      <div class="brand">
        <span class="brand-name">SmartTutor</span>
        <span class="brand-sub">Belgium Campus iTversity</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <a href="/student-dashboard" class="nav-item active">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/my-bookings" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        My Bookings
      </a>
      <a href="/book-session" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Find a Tutor
      </a>
      <a href="/notifications" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        Notifications
      </a>
      <a href="/profile-settings" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
      </a>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
      <div>
        <div class="user-name"><%= user.name %></div>
        <div class="user-role">Student</div>
      </div>
      <!-- Logout button in sidebar -->
      <a href="/logout" class="logout-btn" style="margin-left: auto; color: var(--gray-400); text-decoration: none; font-size: 12px;">🚪 Logout</a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <h1>Good morning, <%= user.name.split(' ')[0] %>! 👋</h1>
        <p>Ready for your studies today? You have <%= stats.upcomingSessions %> sessions this week.</p>
        <h3 style="margin-top:10px; color:#6c63ff;">
        📊 Predicted Performance: <%= prediction %>%
        </h3>
        <p>
  <% if (prediction === "No data yet") { %>
    🚀 Start booking sessions to get predictions!
  <% } else if (prediction < 50) { %>
    ⚠️ You need to study more!
  <% } else if (prediction < 70) { %>
    📘 You are improving!
  <% } else { %>
    🎉 Excellent performance!
  <% } %>
</p>
        <p>
  <% if (noShowRisk === "No data yet") { %>
    🕒 No data yet to assess no-show risk.
  <% } else if (noShowRisk === "High risk ❌") { %>
    ⚠️ You have a high risk of not showing up to sessions.
  <% } else if (noShowRisk === "Moderate risk ⚠️") { %>
    ⚠️ You have a moderate risk of not showing up to sessions.
  <% } else { %>
    ✅ You have a low risk of not showing up to sessions.
  <% } %>
</p>
``

        
      </div>
      <div class="topbar-right">
        <a href="/notifications" class="icon-btn">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </a>
        <a href="/profile-settings" class="user-avatar" style="text-decoration:none;"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></a>
        <!-- Logout button in topbar -->
        <a href="/logout" class="btn btn-ghost btn-sm" style="margin-left: 8px;">Logout</a>
      </div>
    </header>

    <div class="page-content">
      <div class="stat-cards">
        <div class="stat-card">
          <div>
            <div class="stat-label">Total Sessions</div>
            <div class="stat-value"><%= stats.totalSessions %></div>
            <div class="stat-sub">All time</div>
          </div>
          <div class="stat-icon">📚</div>
        </div>
        <div class="stat-card">
          <div>
            <div class="stat-label">Upcoming Sessions</div>
            <div class="stat-value"><%= stats.upcomingSessions %></div>
            <div class="stat-sub">📅 This week</div>
          </div>
          <div class="stat-icon">📅</div>
        </div>
        <div class="stat-card">
          <div>
            <div class="stat-label">Completed</div>
            <div class="stat-value"><%= stats.completedSessions %></div>
            <div class="stat-sub">✅ Sessions done</div>
          </div>
          <div class="stat-icon">✅</div>
        </div>
      </div>
      
      <div class="section-header">
        <span class="section-title">Upcoming Bookings</span>
        <a href="/my-bookings" class="link-turquoise">View All</a>
      </div>
      <div class="booking-list">
        <% if (bookings.length === 0) { %>
          <div class="card" style="text-align:center; padding:40px;">
            <p>No upcoming bookings. <a href="/book-session">Book a session</a> to get started!</p>
          </div>
        <% } else { %>
          <% bookings.forEach(booking => { %>
            <div class="booking-item">
              <div class="booking-info">
                <h4><%= booking.subject.name %> with <%= booking.tutor.name %></h4>
                <div class="booking-meta">
                  <span>📅 <%= new Date(booking.date).toDateString() %> · <%= booking.startTime %>–<%= booking.endTime %></span>
                  <span><%= booking.location === 'online' ? '💻 Online' : '📍 On-campus' %></span>
                </div>
              </div>
              <button class="btn btn-primary btn-sm" onclick="location.href='/my-bookings'">View</button>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </main>
</div>

<style>
  .sidebar-user {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .logout-btn {
    padding: 4px 8px;
    border-radius: 6px;
    transition: all 0.15s;
  }
  .logout-btn:hover {
    background: var(--gray-100);
    color: var(--pink) !important;
  }
</style>
</body>
</html>