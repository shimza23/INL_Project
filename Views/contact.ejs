<%- include('partials/header') %>

<h1>Contact Us</h1>

<div class="admin-section">
  <h2>Send Us a Message</h2>
  <form action="/enquiries" method="POST" class="admin-form">
    <input type="text" name="name" placeholder="Your Full Name" required>
    <input type="email" name="email" placeholder="Your Email Address" required>
    <input type="text" name="subject" placeholder="Subject" required>
    <textarea name="message" placeholder="Your Message" rows="5" required></textarea>
    <button type="submit" class="submit-enquiry-btn">Submit Enquiry</button>
  </form>
</div>


<% if (user && user.role === 'admin') { %>
  <div class="admin-section">
    <h2>Manage User Enquiries</h2>
    
    <% if (enquiries && enquiries.length > 0) { %>
      <table class="admin-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Name</th>
            <th>Email</th>
            <th>Subject</th>
            <th>Message</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% enquiries.forEach(enquiry => { %>
            <tr class="enquiry-row">
              <td><%= new Date(enquiry.createdAt).toLocaleDateString() %></td>
              <td><%= enquiry.name %></td>
              <td><%= enquiry.email %></td>
              <td><%= enquiry.subject %></td>
              <td class="enquiry-message"><%= enquiry.message %></td>
              <td class="enquiry-status">
                <span class="status-badge status-<%= enquiry.status ? enquiry.status.toLowerCase() : 'pending' %>">
                  <%= enquiry.status || 'Pending' %>
                </span>
              </td>
              <td class="enquiry-action">
                <form action="/enquiries/<%= enquiry._id %>?_method=PUT" method="POST" class="inline-form status-form">
                  <select name="status" class="status-select">
                    <option value="Pending" <%= enquiry.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                    <option value="Responded" <%= enquiry.status === 'Responded' ? 'selected' : '' %>>Responded</option>
                    <option value="Closed" <%= enquiry.status === 'Closed' ? 'selected' : '' %>>Closed</option>
                  </select>
                  <button type="submit" class="update-btn">Update</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p class="text-center no-data-message">No enquiries submitted yet.</p>
    <% } %>
  </div>
<% } %>

<% if (success) { %>
  <div class="success success-message"><%= success %></div>
<% } %>

<% if (error) { %>
  <div class="error error-message"><%= error %></div>
<% } %>

<%- include('partials/footer') %>