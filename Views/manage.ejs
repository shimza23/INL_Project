<%- include('partials/header') %>

<h1>Event Management</h1>
<p class="text-center subtitle">Create, update, and delete events</p>

<div class="admin-section">
  <h2>Create New Event</h2>
  <form action="/events" method="POST" class="admin-form">
    <input type="text" name="title" placeholder="Event Title" required>
    <textarea name="description" placeholder="Event Description" rows="3"></textarea>
    <input type="date" name="date" required>
    <select name="category" required>
      <option value="">Select Category</option>
      <option value="conference">Conference</option>
      <option value="workshop">Workshop</option>
      <option value="music festival">Music Festival</option>
      <option value="private">Private Event</option>
    </select>
    <input type="number" name="capacity" placeholder="Total Capacity" min="1" required>
    <button type="submit">Create Event</button>
  </form>
</div>

<div class="admin-section">
  <h2>Manage Existing Events</h2>
  
  <% if (events && events.length > 0) { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Title</th>
          <th>Date</th>
          <th>Category</th>
          <th>Capacity</th>
          <th>Available</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% events.forEach(event => { %>
          <tr class="event-row">
            <td class="event-title"><%= event.title %></td>
            <td><%= event.date %></td>
            <td><%= event.category %></td>
            <td><%= event.capacity %></td>
            <td><%= event.availableTickets %></td>
            <td class="action-buttons">
              
              <form action="/events/<%= event._id %>?_method=PUT" method="POST" class="inline-form update-form">
                <input type="text" name="title" value="<%= event.title %>" class="update-input title-input" required>
                <input type="number" name="capacity" value="<%= event.capacity %>" class="update-input capacity-input" required>
                <input type="number" name="availableTickets" value="<%= event.availableTickets %>" class="update-input tickets-input" required>
                <button type="submit" class="update-btn">Update</button>
              </form>
              
              
              <form action="/events/<%= event._id %>?_method=DELETE" method="POST" class="inline-form delete-form">
                <button type="submit" class="delete-btn" onclick="return confirm('Delete <%= event.title %>? This cannot be undone.')">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p class="text-center no-data-message">No events found. Create your first event above.</p>
  <% } %>
</div>

<%- include('partials/footer') %>