<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Student Requests | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    .request-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .request-card { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius-lg); padding: 16px; }
    .req-avatar { width: 38px; height: 38px; background: var(--turquoise-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; }
    .req-actions { display: flex; gap: 8px; margin-top: 12px; }
  </style>
</head>
<body>
<div class="layout">
  <aside class="sidebar">
    <div class="sidebar-logo"><div class="logo-icon">🎓</div><div class="brand"><span class="brand-name">SmartTutor</span><span class="brand-sub">Belgium Campus iTversity</span></div></div>
    <nav class="sidebar-nav">
      <a href="/tutor-dashboard" class="nav-item">📅 My Schedule</a>
      <a href="/student-requests" class="nav-item active">📋 Student Requests</a>
      <a href="/my-bookings" class="nav-item">📊 Sessions</a>
      <a href="/profile-settings" class="nav-item">👤 Profile</a>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
      <div><div class="user-name"><%= user.name %></div><div class="user-role">Tutor</div></div>
      <a href="/logout" class="logout-btn" style="margin-left: auto; color: var(--gray-400);">🚪 Logout</a>
    </div>
  </aside>

  <main class="main">
    <header class="topbar"><div><h1>Student Requests</h1><p><%= requests.length %> pending</p></div><div><a href="/profile-settings" class="user-avatar"><%= user.name.charAt(0) %></a><a href="/logout" class="btn btn-ghost btn-sm">Logout</a></div></header>

    <div class="page-content">
      <% if (requests.length === 0) { %>
        <div class="card" style="text-align:center; padding:40px;"><p>No pending requests.</p></div>
      <% } else { %>
        <div class="request-grid">
          <% requests.forEach(request => { %>
            <div class="request-card">
              <div class="request-top" style="display:flex; gap:10px; margin-bottom:10px;"><div class="req-avatar"><%= request.student.name.charAt(0) %></div><div><strong><%= request.student.name %></strong><br><%= request.student.studentNumber %></div></div>
              <div class="req-meta">📚 <%= request.subject.name %></div>
              <div class="req-meta">📅 <%= new Date(request.date).toDateString() %> · <%= request.startTime %> (<%= request.duration %> hr)</div>
              <div class="req-desc"><%= request.notes || 'No additional notes' %></div>
              <div class="req-actions"><form method="POST" action="/api/bookings/<%= request._id %>/status?_method=PUT"><input type="hidden" name="status" value="confirmed"><button type="submit" class="btn btn-outline-turquoise btn-sm" style="flex:1">✓ Approve</button></form><form method="POST" action="/api/bookings/<%= request._id %>/status?_method=PUT"><input type="hidden" name="status" value="cancelled"><button type="submit" class="btn btn-outline-pink btn-sm" style="flex:1">✕ Decline</button></form></div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>