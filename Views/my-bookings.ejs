<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SmartTutor – My Bookings</title>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    .filter-bar { display:flex; gap:8px; margin-bottom:18px; flex-wrap:wrap; }
    .filter-btn { padding:6px 16px; border-radius:999px; border:1.5px solid var(--gray-200); background:var(--white); font-size:12px; font-weight:500; color:var(--gray-600); cursor:pointer; font-family:var(--font); transition:all 0.15s; }
    .filter-btn.active { background:var(--turquoise); border-color:var(--turquoise); color:white; }
    .filter-btn:hover:not(.active) { border-color:var(--turquoise); color:var(--turquoise-dark); }
    .booking-item { flex-direction:column; align-items:flex-start; gap:10px; }
    .booking-row { width:100%; display:flex; align-items:center; justify-content:space-between; }
  </style>
</head>
<body>
<div class="layout">
  <div id="sidebar-container"></div>

  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <h1>My Bookings</h1>
        <p>All your tutoring sessions at Belgium Campus iTversity</p>
      </div>
      <div class="topbar-right">
        <button class="btn btn-primary btn-sm" onclick="location.href='/book-session'">+ New Booking</button>
        <a href="/notifications" class="icon-btn">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <span class="notif-dot"></span>
        </a>
        <a href="/profile-settings" class="user-avatar" style="text-decoration:none;">TN</a>
      </div>
    </header>

    <div class="page-content">
      <div class="filter-bar">
        <button class="filter-btn active">All</button>
        <button class="filter-btn">Upcoming</button>
        <button class="filter-btn">Completed</button>
        <button class="filter-btn">Cancelled</button>
      </div>

      <div class="booking-list">
        <div class="booking-item card" style="gap:8px;">
          <div class="booking-row">
            <div class="booking-info">
              <h4>Web Programming (WPR37(8)1)</h4>
              <div class="booking-meta" style="margin-top:4px;">
                <span>👨‍🏫 Sipho Dlamini</span>
                <span>📅 Mon 14 Apr · 14:00–15:30</span>
                <span>💻 Online – MS Teams</span>
              </div>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
              <span class="badge badge-turquoise">Confirmed</span>
              <button class="btn btn-ghost btn-sm">Cancel</button>
            </div>
          </div>
        </div>
        <div class="booking-item card" style="gap:8px;">
          <div class="booking-row">
            <div class="booking-info">
              <h4>Database Design (DBD37(8)1)</h4>
              <div class="booking-meta" style="margin-top:4px;">
                <span>👩‍🏫 Naledi Khumalo</span>
                <span>📅 Wed 16 Apr · 09:00–10:30</span>
                <span>📍 Lab 3, Building B</span>
              </div>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
              <span class="badge badge-turquoise">Confirmed</span>
              <button class="btn btn-ghost btn-sm">Cancel</button>
            </div>
          </div>
        </div>
        <div class="booking-item card" style="gap:8px;">
          <div class="booking-row">
            <div class="booking-info">
              <h4>Machine Learning (MLG37(8)1)</h4>
              <div class="booking-meta" style="margin-top:4px;">
                <span>👨‍🏫 Dr. Ayanda Zulu</span>
                <span>📅 Fri 18 Apr · 11:00–12:00</span>
                <span>💻 Online – MS Teams</span>
              </div>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
              <span class="badge badge-pink">Pending</span>
              <button class="btn btn-ghost btn-sm">Cancel</button>
            </div>
          </div>
        </div>
        <div class="booking-item card" style="gap:8px;">
          <div class="booking-row">
            <div class="booking-info">
              <h4>Linear Programming (LPR271)</h4>
              <div class="booking-meta" style="margin-top:4px;">
                <span>👩‍🏫 Zanele Mokoena</span>
                <span>📅 Mon 7 Apr · 10:00–11:00</span>
                <span>📍 Room 14, Main Block</span>
              </div>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
              <span class="badge badge-gray">Completed</span>
              <button class="btn btn-outline-turquoise btn-sm">Rebook</button>
            </div>
          </div>
        </div>
        <div class="booking-item card" style="gap:8px;">
          <div class="booking-row">
            <div class="booking-info">
              <h4>Data Analytics (DAL371)</h4>
              <div class="booking-meta" style="margin-top:4px;">
                <span>👨‍🏫 Lethabo Sithole</span>
                <span>📅 Thu 3 Apr · 13:00–14:00</span>
                <span>💻 Online – MS Teams</span>
              </div>
            </div>
            <div style="display:flex;gap:8px;align-items:center;">
              <span class="badge badge-gray" style="background:#FEF3C7;color:#92400E;">Cancelled</span>
              <button class="btn btn-outline-turquoise btn-sm">Rebook</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<script src="/js/nav.js"></script>
<script>
  document.getElementById('sidebar-container').innerHTML =
    buildSidebar('student', 'Thabo Nkosi', '3rd Year · IT', '/my-bookings');

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });
</script>
</body>
</html>
