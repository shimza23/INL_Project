<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>My Bookings | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
</head>
<body>
<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">🎓</div>
      <div class="brand">
        <span class="brand-name">SmartTutor</span>
        <span class="brand-sub">Belgium Campus iTversity</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <% if (user.role === 'student') { %>
        <a href="/student-dashboard" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a href="/my-bookings" class="nav-item active">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          My Bookings
        </a>
        <a href="/book-session" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Find a Tutor
        </a>
        <a href="/notifications" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          Notifications
        </a>
        <a href="/profile-settings" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Profile
        </a>
      <% } else if (user.role === 'tutor') { %>
        <a href="/tutor-dashboard" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          My Schedule
        </a>
        <a href="/student-requests" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg>
          Student Requests
        </a>
        <a href="/my-bookings" class="nav-item active">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          Sessions
        </a>
        <a href="/profile-settings" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Profile
        </a>
      <% } %>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
      <div>
        <div class="user-name"><%= user.name %></div>
        <div class="user-role"><%= user.role === 'student' ? 'Student' : 'Tutor' %></div>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <h1>My Bookings</h1>
        <p>All your tutoring sessions</p>
      </div>
      <div class="topbar-right">
        <% if (user.role === 'student') { %>
          <a href="/book-session" class="btn btn-primary btn-sm">+ New Booking</a>
        <% } %>
        <a href="/notifications" class="icon-btn">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </a>
        <a href="/profile-settings" class="user-avatar" style="text-decoration:none;"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></a>
      </div>
    </header>

    <div class="page-content">
      <div class="booking-list">
        <% if (bookings.length === 0) { %>
          <div class="card" style="text-align:center; padding:40px;">
            <p>No bookings yet. 
              <% if (user.role === 'student') { %>
                <a href="/book-session">Book a session</a> to get started!
              <% } else { %>
                Check student requests for pending bookings.
              <% } %>
            </p>
          </div>
        <% } else { %>
          <% bookings.forEach(booking => { %>
            <div class="booking-item">
              <div class="booking-info">
                <h4><%= booking.subject.name %> - <%= booking.subject.code %></h4>
                <div class="booking-meta">
                  <% if (user.role === 'student') { %>
                    <span>👨‍🏫 <%= booking.tutor.name %></span>
                  <% } else { %>
                    <span>👨‍🎓 <%= booking.student.name %></span>
                  <% } %>
                  <span>📅 <%= new Date(booking.date).toDateString() %> · <%= booking.startTime %>–<%= booking.endTime %></span>
                  <span><%= booking.location === 'online' ? '💻 Online' : '📍 On-campus' %></span>
                </div>
                <% if (booking.notes) { %>
                  <div class="booking-meta" style="margin-top: 5px;">
                    <span>📝 Notes: <%= booking.notes %></span>
                  </div>
                <% } %>
              </div>
              <div style="display:flex;gap:8px;align-items:center;">
                <span class="badge badge-<%= booking.status === 'confirmed' ? 'turquoise' : booking.status === 'pending' ? 'pink' : 'gray' %>">
                  <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
                </span>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </main>
</div>
</body>
</html>