<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Notifications | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    .notif-list { display: flex; flex-direction: column; gap: 8px; }
    .notif-item { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 14px 16px; display: flex; align-items: flex-start; gap: 12px; cursor: pointer; transition: all 0.15s; }
    .notif-item:hover { border-color: var(--turquoise); }
    .notif-item.unread { border-left: 3px solid var(--turquoise); background: var(--turquoise-bg); }
    .notif-icon { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; background: var(--turquoise-light); }
    .notif-icon.pink { background: var(--pink-light); }
    .notif-title { font-size: 13px; font-weight: 500; margin-bottom: 2px; }
    .notif-body { font-size: 12px; color: var(--gray-600); margin-bottom: 4px; }
    .notif-time { font-size: 11px; color: var(--gray-400); }
    .unread-dot { width: 8px; height: 8px; background: var(--turquoise); border-radius: 50%; margin-top: 4px; flex-shrink: 0; }
    .sidebar-user {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .logout-btn {
      padding: 4px 8px;
      border-radius: 6px;
      transition: all 0.15s;
    }
    .logout-btn:hover {
      background: var(--gray-100);
      color: var(--pink) !important;
    }
  </style>
</head>
<body>
<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">🎓</div>
      <div class="brand">
        <span class="brand-name">SmartTutor</span>
        <span class="brand-sub">Belgium Campus iTversity</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <% if (user.role === 'student') { %>
        <a href="/student-dashboard" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a href="/my-bookings" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          My Bookings
        </a>
        <a href="/book-session" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Find a Tutor
        </a>
        <a href="/notifications" class="nav-item active">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          Notifications
        </a>
        <a href="/profile-settings" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Profile
        </a>
      <% } else if (user.role === 'tutor') { %>
        <a href="/tutor-dashboard" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          My Schedule
        </a>
        <a href="/student-requests" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg>
          Student Requests
        </a>
        <a href="/my-bookings" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          Sessions
        </a>
        <a href="/profile-settings" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Profile
        </a>
      <% } else if (user.role === 'admin') { %>
        <a href="/admin-analytics" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          Analytics
        </a>
        <a href="/profile-settings" class="nav-item">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-2.82 1.18V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-2.82-1.18l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9 1.65 1.65 0 0 0 4.27 7.18l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
          Settings
        </a>
      <% } %>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
      <div>
        <div class="user-name"><%= user.name %></div>
        <div class="user-role"><%= user.role === 'student' ? 'Student' : user.role === 'tutor' ? 'Tutor' : 'Admin' %></div>
      </div>
      <a href="/logout" class="logout-btn" style="margin-left: auto; color: var(--gray-400); text-decoration: none; font-size: 12px;">🚪 Logout</a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <h1>Notifications</h1>
        <p><%= unreadCount %> unread notifications</p>
      </div>
      <div class="topbar-right">
        <button class="btn btn-ghost btn-sm" onclick="markAllRead()">Mark all as read</button>
        <a href="/profile-settings" class="user-avatar" style="text-decoration:none;"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></a>
        <a href="/logout" class="btn btn-ghost btn-sm" style="margin-left: 8px;">Logout</a>
      </div>
    </header>

    <div class="page-content">
      <div class="notif-list">
        <% if (notifications.length === 0) { %>
          <div class="card" style="text-align:center; padding:40px;">
            <p>🔔 No notifications yet. Check back later!</p>
          </div>
        <% } else { %>
          <% notifications.forEach(notif => { %>
            <div class="notif-item <%= !notif.isRead ? 'unread' : '' %>" onclick="markRead('<%= notif._id %>')">
              <div class="notif-icon <%= notif.type === 'booking' ? '' : 'pink' %>">
                <%= notif.type === 'booking' ? '📅' : notif.type === 'reminder' ? '⏰' : '🔔' %>
              </div>
              <div style="flex:1;">
                <div class="notif-title"><%= notif.title %></div>
                <div class="notif-body"><%= notif.message %></div>
                <div class="notif-time"><%= new Date(notif.createdAt).toLocaleDateString() %> at <%= new Date(notif.createdAt).toLocaleTimeString() %></div>
              </div>
              <% if (!notif.isRead) { %>
                <div class="unread-dot"></div>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </main>
</div>

<script>
  async function markRead(id) {
    try {
      await fetch(`/api/notifications/${id}/read`, { method: 'PUT' });
      location.reload();
    } catch (error) {
      console.error('Error marking notification as read:', error);
    }
  }
  
  async function markAllRead() {
    try {
      await fetch(`/api/notifications/user/read-all`, { method: 'PUT' });
      location.reload();
    } catch (error) {
      console.error('Error marking all notifications as read:', error);
    }
  }
</script>
</body>
</html>