<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Notifications | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    .notif-list { display: flex; flex-direction: column; gap: 8px; }
    .notif-item { background: var(--white); border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 14px 16px; display: flex; align-items: flex-start; gap: 12px; cursor: pointer; transition: all 0.15s; }
    .notif-item.unread { border-left: 3px solid var(--turquoise); background: var(--turquoise-bg); }
    .notif-icon { width: 36px; height: 36px; border-radius: 50%; background: var(--turquoise-light); display: flex; align-items: center; justify-content: center; font-size: 16px; }
    .notif-icon.pink { background: var(--pink-light); }
    .unread-dot { width: 8px; height: 8px; background: var(--turquoise); border-radius: 50%; margin-top: 4px; }
  </style>
</head>
<body>
<div class="layout">
  <aside class="sidebar">
    <div class="sidebar-logo"><div class="logo-icon">🎓</div><div class="brand"><span class="brand-name">SmartTutor</span><span class="brand-sub">Belgium Campus iTversity</span></div></div>
    <nav class="sidebar-nav">
      <% if (user.role === 'student') { %>
        <a href="/student-dashboard" class="nav-item">📊 Dashboard</a>
        <a href="/my-bookings" class="nav-item">📅 My Bookings</a>
        <a href="/book-session" class="nav-item">🔍 Find a Tutor</a>
        <a href="/notifications" class="nav-item active">🔔 Notifications</a>
        <a href="/profile-settings" class="nav-item">👤 Profile</a>
      <% } else if (user.role === 'tutor') { %>
        <a href="/tutor-dashboard" class="nav-item">📅 My Schedule</a>
        <a href="/student-requests" class="nav-item">📋 Student Requests</a>
        <a href="/my-bookings" class="nav-item">📊 Sessions</a>
        <a href="/profile-settings" class="nav-item">👤 Profile</a>
      <% } %>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
      <div><div class="user-name"><%= user.name %></div><div class="user-role"><%= user.role === 'student' ? 'Student' : 'Tutor' %></div></div>
      <a href="/logout" class="logout-btn" style="margin-left: auto; color: var(--gray-400);">🚪 Logout</a>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <div class="topbar-left"><h1>Notifications</h1><p><%= unreadCount %> unread</p></div>
      <div class="topbar-right"><button class="btn btn-ghost btn-sm" onclick="markAllRead()">Mark all as read</button><a href="/profile-settings" class="user-avatar"><%= user.name.charAt(0) %></a><a href="/logout" class="btn btn-ghost btn-sm">Logout</a></div>
    </header>

    <div class="page-content">
      <div class="notif-list">
        <% if (notifications.length === 0) { %>
          <div class="card" style="text-align:center; padding:40px;"><p>🔔 No notifications yet.</p></div>
        <% } else { %>
          <% notifications.forEach(notif => { %>
            <div class="notif-item <%= !notif.isRead ? 'unread' : '' %>" onclick="markRead('<%= notif._id %>')">
              <div class="notif-icon <%= notif.type === 'booking' ? '' : 'pink' %>"><%= notif.type === 'booking' ? '📅' : notif.type === 'review' ? '⭐' : '🔔' %></div>
              <div style="flex:1;"><div class="notif-title"><%= notif.title %></div><div class="notif-body"><%= notif.message %></div><div class="notif-time"><%= new Date(notif.createdAt).toLocaleDateString() %></div></div>
              <% if (!notif.isRead) { %><div class="unread-dot"></div><% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </main>
</div>

<script>
  async function markRead(id) { await fetch(`/api/notifications/${id}/read`, { method: 'PUT' }); location.reload(); }
  async function markAllRead() { await fetch(`/api/notifications/user/read-all`, { method: 'PUT' }); location.reload(); }
</script>
</body>
</html>