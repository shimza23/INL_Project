<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SmartTutor – Notifications</title>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    .notif-list { display:flex; flex-direction:column; gap:8px; }
    .notif-item { background:var(--white); border:1px solid var(--gray-200); border-radius:var(--radius); padding:14px 16px; display:flex; align-items:flex-start; gap:12px; cursor:pointer; transition:all 0.15s; }
    .notif-item:hover { border-color:var(--turquoise); }
    .notif-item.unread { border-left:3px solid var(--turquoise); background:var(--turquoise-bg); }
    .notif-icon { width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0; background:var(--turquoise-light); }
    .notif-icon.pink { background:var(--pink-light); }
    .notif-title { font-size:13px; font-weight:500; margin-bottom:2px; }
    .notif-body { font-size:12px; color:var(--gray-600); margin-bottom:4px; }
    .notif-time { font-size:11px; color:var(--gray-400); }
    .unread-dot { width:8px; height:8px; background:var(--turquoise); border-radius:50%; margin-top:4px; flex-shrink:0; }
  </style>
</head>
<body>
<div class="layout">
  <div id="sidebar-container"></div>

  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <h1>Notifications</h1>
        <p>3 unread notifications</p>
      </div>
      <div class="topbar-right">
        <button class="btn btn-ghost btn-sm">Mark all as read</button>
        <a href="/profile-settings" class="user-avatar" style="text-decoration:none;">TN</a>
      </div>
    </header>

    <div class="page-content">
      <div class="notif-list">
        <div class="notif-item unread">
          <div class="notif-icon">✅</div>
          <div style="flex:1;">
            <div class="notif-title">Booking Confirmed – Web Programming</div>
            <div class="notif-body">Your session with Sipho Dlamini on Monday 14 Apr at 14:00 has been confirmed.</div>
            <div class="notif-time">2 hours ago</div>
          </div>
          <div class="unread-dot"></div>
        </div>
        <div class="notif-item unread">
          <div class="notif-icon pink">⏰</div>
          <div style="flex:1;">
            <div class="notif-title">Session Reminder – Database Design</div>
            <div class="notif-body">Your DBD37(8)1 session with Naledi Khumalo is tomorrow at 09:00 in Lab 3.</div>
            <div class="notif-time">5 hours ago</div>
          </div>
          <div class="unread-dot"></div>
        </div>
        <div class="notif-item unread">
          <div class="notif-icon">🤖</div>
          <div style="flex:1;">
            <div class="notif-title">No-show Risk Alert – Machine Learning</div>
            <div class="notif-body">Our system predicts you may miss your MLG session on Friday. Would you like to reschedule?</div>
            <div class="notif-time">1 day ago</div>
          </div>
          <div class="unread-dot"></div>
        </div>
        <div class="notif-item">
          <div class="notif-icon">📋</div>
          <div style="flex:1;">
            <div class="notif-title">New Tutor Available – Linear Programming</div>
            <div class="notif-body">Zanele Mokoena has opened new slots for LPR271 tutoring this week.</div>
            <div class="notif-time">3 days ago</div>
          </div>
        </div>
        <div class="notif-item">
          <div class="notif-icon pink">❌</div>
          <div style="flex:1;">
            <div class="notif-title">Session Cancelled – Data Analytics</div>
            <div class="notif-body">Your DAL371 session on Thu 3 Apr was cancelled by the tutor. Please rebook.</div>
            <div class="notif-time">1 week ago</div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>

<script src="/js/nav.js"></script>
<script>
  document.getElementById('sidebar-container').innerHTML =
    buildSidebar('student', 'Thabo Nkosi', '3rd Year · IT', '/notifications');
</script>
</body>
</html>
