<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SmartTutor – Book a Session</title>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    .book-heading { text-align:center; margin-bottom:24px; }
    .book-heading h2 { font-size:20px; font-weight:600; margin-bottom:4px; }
    .book-heading p { font-size:13px; color:var(--gray-400); }
    .book-actions { display:flex; justify-content:space-between; align-items:center; padding-top:8px; }
  </style>
</head>
<body>
<div class="layout">
  <div id="sidebar-container"></div>

  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <h1>Book a Tutoring Session</h1>
        <p>Select a Belgium Campus iTversity module to get started</p>
      </div>
      <div class="topbar-right">
        <a href="/notifications" class="icon-btn">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <span class="notif-dot"></span>
        </a>
        <a href="/profile-settings" class="user-avatar" style="text-decoration:none;">TN</a>
      </div>
    </header>

    <div class="page-content">
      <div class="steps">
        <div class="step">
          <div class="step-circle active">1</div>
          <span class="step-label active">Module</span>
        </div>
        <div class="step-line"></div>
        <div class="step">
          <div class="step-circle">2</div>
          <span class="step-label">Schedule</span>
        </div>
        <div class="step-line"></div>
        <div class="step">
          <div class="step-circle">3</div>
          <span class="step-label">Confirm</span>
        </div>
      </div>

      <div class="book-heading">
        <h2>Choose Your Module</h2>
        <p>Belgium Campus iTversity – 3rd Year IT modules available for tutoring</p>
      </div>

      <div class="subject-grid">
        <div class="subject-card selected" onclick="selectSubject(this)">
          <div class="subject-icon">🌐</div>
          <div class="subject-name">Web Programming</div>
          <div class="subject-code">WPR37(8)1</div>
          <div class="subject-sub">JavaScript, Node.js, EJS</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">🗄️</div>
          <div class="subject-name">Database Design</div>
          <div class="subject-code">DBD37(8)1</div>
          <div class="subject-sub">MongoDB, Data Modelling</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">🤖</div>
          <div class="subject-name">Machine Learning</div>
          <div class="subject-code">MLG37(8)1</div>
          <div class="subject-sub">Prediction, Classification</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">📊</div>
          <div class="subject-name">Data Analytics</div>
          <div class="subject-code">DAL371</div>
          <div class="subject-sub">Power BI, Dashboards</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">🧠</div>
          <div class="subject-name">Machine Learning II</div>
          <div class="subject-code">MLG37(8)2</div>
          <div class="subject-sub">Deep Learning, NLP</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">📋</div>
          <div class="subject-name">Project Management</div>
          <div class="subject-code">PMM37(8)1</div>
          <div class="subject-sub">Agile, Planning, RACI</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">💡</div>
          <div class="subject-name">Innovation Management</div>
          <div class="subject-code">INM37(8)1</div>
          <div class="subject-sub">Design Thinking, Strategy</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">🎨</div>
          <div class="subject-name">UX Design</div>
          <div class="subject-code">UAX37(8)1</div>
          <div class="subject-sub">Figma, Prototyping, UX</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">🔗</div>
          <div class="subject-name">Integration Leadership</div>
          <div class="subject-code">INL37(8)1</div>
          <div class="subject-sub">Deployment, Architecture</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">📐</div>
          <div class="subject-name">Linear Programming</div>
          <div class="subject-code">LPR271</div>
          <div class="subject-sub">Optimisation, Simplex</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">💻</div>
          <div class="subject-name">Programming</div>
          <div class="subject-code">PRG271</div>
          <div class="subject-sub">C#, OOP, Algorithms</div>
        </div>
        <div class="subject-card" onclick="selectSubject(this)">
          <div class="subject-icon">🔒</div>
          <div class="subject-name">Cybersecurity</div>
          <div class="subject-code">CYB371</div>
          <div class="subject-sub">Auth, Encryption, OWASP</div>
        </div>
      </div>

      <div class="book-actions">
        <button class="btn btn-ghost" onclick="location.href='/student-dashboard'">Back</button>
        <button class="btn btn-primary">Next Step →</button>
      </div>
    </div>
  </main>
</div>

<script src="/js/nav.js"></script>
<script>
  document.getElementById('sidebar-container').innerHTML =
    buildSidebar('student', 'Thabo Nkosi', '3rd Year · IT', '/book-session');

  function selectSubject(el) {
    document.querySelectorAll('.subject-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
  }
</script>
</body>
</html>
