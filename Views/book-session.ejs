<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Book a Session | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
</head>
<body>
<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">🎓</div>
      <div class="brand">
        <span class="brand-name">SmartTutor</span>
        <span class="brand-sub">Belgium Campus iTversity</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <a href="/student-dashboard" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/my-bookings" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        My Bookings
      </a>
      <a href="/book-session" class="nav-item active">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Find a Tutor
      </a>
      <a href="/notifications" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        Notifications
      </a>
      <a href="/profile-settings" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
      </a>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
      <div>
        <div class="user-name"><%= user.name %></div>
        <div class="user-role">Student</div>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <h1>Book a Tutoring Session</h1>
        <p>Select a module, then choose from available tutors</p>
      </div>
      <div class="topbar-right">
        <a href="/notifications" class="icon-btn">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </a>
        <a href="/profile-settings" class="user-avatar" style="text-decoration:none;"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></a>
      </div>
    </header>

    <div class="page-content">
      <div class="card">
        <form method="POST" action="/api/bookings" id="bookingForm">
          <div class="form-group">
            <label class="form-label">Select Module</label>
            <select class="form-input" name="subjectId" id="subjectSelect" required>
              <option value="">Choose a module...</option>
              <% subjects.forEach(subject => { %>
                <option value="<%= subject._id %>" <%= selectedSubjectId === subject._id.toString() ? 'selected' : '' %>>
                  <%= subject.code %> - <%= subject.name %>
                </option>
              <% }) %>
            </select>
          </div>
          
          <div class="form-group">
            <label class="form-label">Select Tutor</label>
            <select class="form-input" name="tutorId" id="tutorSelect" required>
              <option value="">First select a module...</option>
              <% if (tutors && tutors.length > 0) { %>
                <% tutors.forEach(tutor => { %>
                  <option value="<%= tutor._id %>"><%= tutor.name %> (⭐ <%= tutor.rating || 0 %>) - Teaches: <%= tutor.modules.join(', ') %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Date</label>
              <input class="form-input" type="date" name="date" required>
            </div>
            <div class="form-group">
              <label class="form-label">Start Time</label>
              <input class="form-input" type="time" name="startTime" required>
            </div>
            <div class="form-group">
              <label class="form-label">End Time</label>
              <input class="form-input" type="time" name="endTime" required>
            </div>
          </div>
          
          <div class="form-group">
            <label class="form-label">Location</label>
            <select class="form-input" name="location">
              <option value="online">💻 Online (MS Teams)</option>
              <option value="oncampus">📍 On-campus</option>
            </select>
          </div>
          
          <div class="form-group">
            <label class="form-label">Additional Notes</label>
            <textarea class="form-input" name="notes" rows="3" placeholder="What do you need help with?"></textarea>
          </div>
          
          <div class="form-actions">
            <a href="/student-dashboard" class="btn btn-ghost">Cancel</a>
            <button type="submit" class="btn btn-primary">Submit Booking Request</button>
          </div>
        </form>
      </div>
    </div>
  </main>
</div>

<script>
  const subjectSelect = document.getElementById('subjectSelect');
  const tutorSelect = document.getElementById('tutorSelect');
  
  async function loadTutors(subjectId) {
    if (!subjectId) {
      tutorSelect.innerHTML = '<option value="">First select a module...</option>';
      return;
    }
    
    tutorSelect.innerHTML = '<option value="">Loading tutors...</option>';
    
    try {
      const response = await fetch(`/api/tutors/by-subject/${subjectId}`);
      const tutors = await response.json();
      
      if (tutors.length === 0) {
        tutorSelect.innerHTML = '<option value="">No tutors available for this module</option>';
      } else {
        tutorSelect.innerHTML = '<option value="">Select a tutor...</option>' + 
          tutors.map(tutor => `<option value="${tutor._id}">${tutor.name} (⭐ ${tutor.rating || 0}) - Teaches: ${tutor.modules.join(', ')}</option>`).join('');
      }
    } catch (error) {
      console.error('Error loading tutors:', error);
      tutorSelect.innerHTML = '<option value="">Error loading tutors</option>';
    }
  }
  
  // Load tutors when subject changes
  subjectSelect.addEventListener('change', (e) => {
    loadTutors(e.target.value);
  });
  
  // Load tutors on page load if a subject is preselected
  if (subjectSelect.value) {
    loadTutors(subjectSelect.value);
  }
</script>
</body>
</html>