<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Book a Session | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    .time-slots-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-top: 8px;
    }
    .time-slot {
      padding: 8px;
      border: 1.5px solid var(--gray-200);
      border-radius: var(--radius-sm);
      background: var(--white);
      cursor: pointer;
      text-align: center;
      font-size: 13px;
      transition: all 0.15s;
    }
    .time-slot:hover:not(.disabled):not(.past) {
      border-color: var(--turquoise);
      background: var(--turquoise-bg);
    }
    .time-slot.selected {
      border-color: var(--turquoise);
      background: var(--turquoise);
      color: white;
    }
    .time-slot.disabled {
      background: var(--gray-100);
      color: var(--gray-400);
      cursor: not-allowed;
      text-decoration: line-through;
    }
    .time-slot.past {
      background: var(--gray-100);
      color: var(--gray-400);
      cursor: not-allowed;
      opacity: 0.6;
      text-decoration: line-through;
    }
    .duration-buttons {
      display: flex;
      gap: 10px;
      margin-top: 8px;
    }
    .duration-btn {
      flex: 1;
      padding: 10px;
      border: 1.5px solid var(--gray-200);
      border-radius: var(--radius-sm);
      background: var(--white);
      cursor: pointer;
      text-align: center;
      transition: all 0.15s;
    }
    .duration-btn:hover {
      border-color: var(--turquoise);
      background: var(--turquoise-bg);
    }
    .duration-btn.selected {
      border-color: var(--turquoise);
      background: var(--turquoise);
      color: white;
    }
    .sidebar-user {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .logout-btn {
      padding: 4px 8px;
      border-radius: 6px;
      transition: all 0.15s;
      text-decoration: none;
    }
    .logout-btn:hover {
      background: var(--gray-100);
      color: var(--pink) !important;
    }
    .alert {
      padding: 12px;
      border-radius: var(--radius-sm);
      margin-bottom: 16px;
    }
    .alert-error {
      background: #FEE2E2;
      color: #DC2626;
    }
    .alert-success {
      background: #D1FAE5;
      color: #065F46;
    }
  </style>
</head>
<body>
<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">🎓</div>
      <div class="brand">
        <span class="brand-name">SmartTutor</span>
        <span class="brand-sub">Belgium Campus iTversity</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <a href="/student-dashboard" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/my-bookings" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        My Bookings
      </a>
      <a href="/book-session" class="nav-item active">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Find a Tutor
      </a>
      <a href="/notifications" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        Notifications
      </a>
      <a href="/profile-settings" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
      </a>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
      <div>
        <div class="user-name"><%= user.name %></div>
        <div class="user-role">Student</div>
      </div>
      <a href="/logout" class="logout-btn" style="margin-left: auto; color: var(--gray-400);">🚪 Logout</a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <h1>Book a Tutoring Session</h1>
        <p>Select a module, tutor, and available time slot</p>
      </div>
      <div class="topbar-right">
        <a href="/notifications" class="icon-btn">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </a>
        <a href="/profile-settings" class="user-avatar" style="text-decoration:none;"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></a>
        <a href="/logout" class="btn btn-ghost btn-sm" style="margin-left: 8px;">Logout</a>
      </div>
    </header>

    <div class="page-content">
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>
      
      <div class="card">
        <form method="POST" action="/api/bookings" id="bookingForm">
          <div class="form-group">
            <label class="form-label">Select Module</label>
            <select class="form-input" name="subjectId" id="subjectSelect" required>
              <option value="">Choose a module...</option>
              <% subjects.forEach(subject => { %>
                <option value="<%= subject._id %>" <%= selectedSubjectId === subject._id.toString() ? 'selected' : '' %>>
                  <%= subject.code %> - <%= subject.name %>
                </option>
              <% }) %>
            </select>
          </div>
          
          <div class="form-group">
            <label class="form-label">Select Tutor</label>
            <select class="form-input" name="tutorId" id="tutorSelect" required>
              <option value="">First select a module...</option>
              <% if (tutors && tutors.length > 0) { %>
                <% tutors.forEach(tutor => { %>
                  <option value="<%= tutor._id %>"><%= tutor.name %> (⭐ <%= tutor.rating || 0 %>) - Teaches: <%= tutor.modules.join(', ') %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
          
          <div class="form-group">
            <label class="form-label">Select Date</label>
            <input class="form-input" type="date" name="date" id="dateSelect" required min="<%= new Date().toISOString().split('T')[0] %>">
          </div>
          
          <div class="form-group">
            <label class="form-label">Select Duration</label>
            <div class="duration-buttons">
              <% durations.forEach(duration => { %>
                <button type="button" class="duration-btn" data-duration="<%= duration.value %>">
                  <%= duration.label %>
                </button>
              <% }) %>
            </div>
            <input type="hidden" name="duration" id="durationInput" required>
          </div>
          
          <div class="form-group">
            <label class="form-label">Select Start Time (30-minute intervals)</label>
            <div class="time-slots-grid" id="timeSlotsGrid">
              <div class="time-slot disabled">Select a tutor, date, and duration first</div>
            </div>
            <input type="hidden" name="startTime" id="startTimeInput" required>
          </div>
          
          <div class="form-group">
            <label class="form-label">Location</label>
            <select class="form-input" name="location">
              <option value="online">💻 Online (MS Teams)</option>
              <option value="oncampus">📍 On-campus</option>
            </select>
          </div>
          
          <div class="form-group">
            <label class="form-label">Additional Notes</label>
            <textarea class="form-input" name="notes" rows="3" placeholder="What do you need help with?"></textarea>
          </div>
          
          <div class="form-actions">
            <a href="/student-dashboard" class="btn btn-ghost">Cancel</a>
            <button type="submit" class="btn btn-primary">Submit Booking Request</button>
          </div>
        </form>
      </div>
    </div>
  </main>
</div>

<script>
  const subjectSelect = document.getElementById('subjectSelect');
  const tutorSelect = document.getElementById('tutorSelect');
  const dateSelect = document.getElementById('dateSelect');
  const timeSlotsGrid = document.getElementById('timeSlotsGrid');
  const startTimeInput = document.getElementById('startTimeInput');
  const durationInput = document.getElementById('durationInput');
  let selectedDuration = null;
  let selectedTimeSlot = null;
  
  // Set min date to today
  const today = new Date().toISOString().split('T')[0];
  dateSelect.min = today;
  
  // Check if a time slot is in the past
  function isPastTimeSlot(timeSlot, selectedDate) {
    const now = new Date();
    const slotDate = new Date(selectedDate);
    const [hours, minutes] = timeSlot.split(':').map(Number);
    slotDate.setHours(hours, minutes, 0, 0);
    return slotDate < now;
  }
  
  // Load tutors when subject changes
  subjectSelect.addEventListener('change', async (e) => {
    if (e.target.value) {
      const response = await fetch(`/api/tutors/by-subject/${e.target.value}`);
      const tutors = await response.json();
      
      tutorSelect.innerHTML = '<option value="">Select a tutor...</option>';
      tutors.forEach(tutor => {
        tutorSelect.innerHTML += `<option value="${tutor._id}">${tutor.name} (⭐ ${tutor.rating || 0}) - Teaches: ${tutor.modules.join(', ')}</option>`;
      });
    } else {
      tutorSelect.innerHTML = '<option value="">First select a module...</option>';
    }
    timeSlotsGrid.innerHTML = '<div class="time-slot disabled">Select a tutor and date first</div>';
  });
  
  // Load available time slots when tutor or date changes
  async function loadTimeSlots() {
    const tutorId = tutorSelect.value;
    const date = dateSelect.value;
    
    if (!tutorId || !date || !selectedDuration) {
      timeSlotsGrid.innerHTML = '<div class="time-slot disabled">Select tutor, date, and duration first</div>';
      return;
    }
    
    const response = await fetch(`/api/available-slots/${tutorId}/${date}`);
    let availableSlots = await response.json();
    
    // Filter out past time slots for today's date
    const todayStr = new Date().toISOString().split('T')[0];
    if (date === todayStr) {
      availableSlots = availableSlots.filter(slot => !isPastTimeSlot(slot, date));
    }
    
    if (availableSlots.length === 0) {
      timeSlotsGrid.innerHTML = '<div class="time-slot disabled">No available time slots for this date</div>';
      return;
    }
    
    timeSlotsGrid.innerHTML = '';
    availableSlots.forEach(slot => {
      const slotDiv = document.createElement('div');
      slotDiv.className = 'time-slot';
      slotDiv.textContent = slot;
      
      // Check if slot is in the past
      if (date === todayStr && isPastTimeSlot(slot, date)) {
        slotDiv.classList.add('past');
        slotDiv.style.cursor = 'not-allowed';
      } else {
        slotDiv.onclick = () => selectTimeSlot(slotDiv, slot);
      }
      
      timeSlotsGrid.appendChild(slotDiv);
    });
  }
  
  function selectTimeSlot(element, slot) {
    // Don't allow selecting past time slots
    if (element.classList.contains('past')) {
      return;
    }
    
    // Remove selected class from all time slots
    document.querySelectorAll('.time-slot').forEach(el => {
      el.classList.remove('selected');
    });
    element.classList.add('selected');
    selectedTimeSlot = slot;
    startTimeInput.value = slot;
  }
  
  // Duration selection
  document.querySelectorAll('.duration-btn').forEach(btn => {
    btn.onclick = () => {
      document.querySelectorAll('.duration-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      selectedDuration = btn.dataset.duration;
      durationInput.value = selectedDuration;
      if (tutorSelect.value && dateSelect.value) {
        loadTimeSlots();
      }
    };
  });
  
  tutorSelect.addEventListener('change', () => {
    if (tutorSelect.value && dateSelect.value && selectedDuration) {
      loadTimeSlots();
    } else if (tutorSelect.value && dateSelect.value) {
      timeSlotsGrid.innerHTML = '<div class="time-slot disabled">Select duration first</div>';
    }
  });
  
  dateSelect.addEventListener('change', () => {
    if (tutorSelect.value && dateSelect.value && selectedDuration) {
      loadTimeSlots();
    } else if (tutorSelect.value && dateSelect.value) {
      timeSlotsGrid.innerHTML = '<div class="time-slot disabled">Select duration first</div>';
    }
  });
  
  // Load tutors on page load if a subject is preselected
  if (subjectSelect.value) {
    subjectSelect.dispatchEvent(new Event('change'));
  }
</script>
</body>
</html>