<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tutor Dashboard | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
</head>
<body>
<div class="layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">🎓</div>
      <div class="brand">
        <span class="brand-name">SmartTutor</span>
        <span class="brand-sub">Belgium Campus iTversity</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <a href="/tutor-dashboard" class="nav-item active">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        My Schedule
      </a>
      <a href="/student-requests" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg>
        Student Requests
      </a>
      <a href="/my-bookings" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        Sessions
      </a>
      <a href="/profile-settings" class="nav-item">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
      </a>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
      <div>
        <div class="user-name"><%= user.name %></div>
        <div class="user-role">Tutor</div>
      </div>
      <a href="/logout" class="logout-btn" style="margin-left: auto; color: var(--gray-400); text-decoration: none; font-size: 12px;">🚪 Logout</a>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <h1>My Schedule</h1>
        <p>Manage your availability and tutoring sessions</p>
      </div>
      <div class="topbar-right">
        <a href="/profile-settings" class="user-avatar" style="text-decoration:none;"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></a>
        <a href="/logout" class="btn btn-ghost btn-sm" style="margin-left: 8px;">Logout</a>
      </div>
    </header>

    <div class="page-content">
      <div class="stat-cards-4">
        <div class="stat-card">
          <div>
            <div class="stat-label">Pending Requests</div>
            <div class="stat-value"><%= stats.pendingRequests %></div>
          </div>
          <div class="stat-icon">⏳</div>
        </div>
        <div class="stat-card">
          <div>
            <div class="stat-label">Total Sessions</div>
            <div class="stat-value"><%= stats.totalSessions %></div>
          </div>
          <div class="stat-icon">📊</div>
        </div>
        <div class="stat-card">
          <div>
            <div class="stat-label">Rating</div>
            <div class="stat-value"><%= stats.rating %></div>
          </div>
          <div class="stat-icon">⭐</div>
        </div>
        <div class="stat-card">
          <div>
            <div class="stat-label">Completed</div>
            <div class="stat-value"><%= stats.totalSessions %></div>
          </div>
          <div class="stat-icon">✅</div>
        </div>
      </div>

      <div class="section-header">
        <span class="section-title">Upcoming Sessions</span>
        <a href="/my-bookings" class="link-turquoise">View All</a>
      </div>
      <div class="booking-list">
        <% if (bookings.length === 0) { %>
          <div class="card" style="text-align:center; padding:40px;">
            <p>No upcoming sessions. Check student requests to get started!</p>
          </div>
        <% } else { %>
          <% bookings.forEach(booking => { %>
            <div class="booking-item">
              <div class="booking-info">
                <h4><%= booking.subject.name %> with <%= booking.student.name %></h4>

                <!-- HERE WE ADDED THE no-show risk indicator -->
                 
                <p style="font-size: 12px; margin-top: 5px;">
                  🚨 Risk: <%= booking.noShowRisk || "Unknown" %>
                </p>

                <div class="booking-meta">
                  <span>📅 <%= new Date(booking.date).toDateString() %> · <%= booking.startTime %>–<%= booking.endTime %></span>
                  <span><%= booking.location === 'online' ? '💻 Online' : '📍 On-campus' %></span>
                </div>
              </div>
              <button class="btn btn-primary btn-sm" onclick="location.href='/my-bookings'">View Details</button>
            </div>
          <% }) %>
        <% } %>
      </div>

      <div style="margin-top: 20px; text-align: center;">
        <a href="/student-requests" class="btn btn-primary">View Pending Requests (<%= stats.pendingRequests %>)</a>
      </div>
    </div>
  </main>
</div>

<style>
  .sidebar-user {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .logout-btn {
    padding: 4px 8px;
    border-radius: 6px;
    transition: all 0.15s;
  }
  .logout-btn:hover {
    background: var(--gray-100);
    color: var(--pink) !important;
  }
</style>
</body>
</html>