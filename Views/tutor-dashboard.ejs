<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tutor Dashboard | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    .attendance-buttons {
      display: flex;
      gap: 8px;
      margin-top: 8px;
    }
    .btn-attend {
      background: #10B981;
      color: white;
      border: none;
      padding: 6px 14px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
    }
    .btn-attend:hover {
      background: #059669;
      transform: translateY(-1px);
    }
    .btn-miss {
      background: #EF4444;
      color: white;
      border: none;
      padding: 6px 14px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 12px;
      font-weight: 500;
    }
    .btn-miss:hover {
      background: #DC2626;
      transform: translateY(-1px);
    }
    .attendance-badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 12px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
    }
    .attendance-attended {
      background: #D1FAE5;
      color: #065F46;
    }
    .attendance-missed {
      background: #FEE2E2;
      color: #DC2626;
    }
    .attendance-pending {
      background: #FEF3C7;
      color: #92400E;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 20px;
      margin-bottom: 28px;
    }
    .stat-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      border: 1px solid var(--gray-200);
      padding: 20px;
      text-align: center;
      transition: all 0.2s ease;
    }
    .stat-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-lg);
    }
    .stat-value {
      font-size: 32px;
      font-weight: 700;
      color: var(--gray-800);
    }
    .stat-label {
      font-size: 12px;
      color: var(--gray-500);
      margin-top: 8px;
    }
    .alert {
      padding: 14px 18px;
      border-radius: 12px;
      margin-bottom: 20px;
    }
    .alert-success {
      background: #D1FAE5;
      color: #065F46;
      border-left: 4px solid #065F46;
    }
    .alert-error {
      background: #FEE2E2;
      color: #DC2626;
      border-left: 4px solid #DC2626;
    }
    .pending-card {
      background: linear-gradient(135deg, #FEF3C7 0%, #FFFBEB 100%);
      border-left: 4px solid #F59E0B;
    }
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      margin-top: 24px;
    }
    .section-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--gray-800);
    }
    .badge {
      padding: 4px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
    }
    .badge-yellow {
      background: #FEF3C7;
      color: #92400E;
    }
    .booking-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .booking-item {
      background: var(--white);
      border: 1px solid var(--gray-200);
      border-radius: var(--radius);
      padding: 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
      transition: all 0.2s ease;
    }
    .booking-item:hover {
      border-color: var(--turquoise);
      box-shadow: var(--shadow);
    }
    .booking-info {
      flex: 1;
    }
    .booking-info h4 {
      font-size: 16px;
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--gray-800);
    }
    .booking-meta {
      font-size: 13px;
      color: var(--gray-500);
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }
    .card {
      background: white;
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 24px;
    }
    .rating-card {
      background: linear-gradient(135deg, #FBBF24 0%, #F59E0B 100%);
      color: white;
    }
    .rating-card .stat-value {
      color: white;
    }
    .rating-card .stat-label {
      color: rgba(255,255,255,0.9);
    }
    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
      margin-bottom: 24px;
    }
    .review-card {
      background: var(--white);
      border-radius: var(--radius-lg);
      border: 1px solid var(--gray-200);
      padding: 20px;
      transition: all 0.2s ease;
    }
    .review-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }
    .review-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }
    .review-stars {
      color: #FBBF24;
      font-size: 16px;
      letter-spacing: 2px;
    }
    .review-student {
      font-weight: 600;
      color: var(--gray-700);
    }
    .review-date {
      font-size: 11px;
      color: var(--gray-400);
    }
    .review-comment {
      color: var(--gray-600);
      line-height: 1.5;
      margin-top: 10px;
    }
    .rating-distribution-bar {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }
    .rating-label {
      width: 45px;
      font-size: 13px;
    }
    .rating-bar-track {
      flex: 1;
      height: 8px;
      background: var(--gray-200);
      border-radius: 4px;
      overflow: hidden;
    }
    .rating-bar-fill {
      height: 100%;
      background: #FBBF24;
      border-radius: 4px;
    }
    .rating-count {
      width: 35px;
      font-size: 12px;
      color: var(--gray-500);
    }
    .no-reviews {
      text-align: center;
      padding: 40px;
      color: var(--gray-400);
    }
  </style>
</head>
<body>
<div class="layout">
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">🎓</div>
      <div class="brand">
        <span class="brand-name">SmartTutor</span>
        <span class="brand-sub">Belgium Campus iTversity</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <a href="/tutor-dashboard" class="nav-item active">📅 My Schedule</a>
      <a href="/student-requests" class="nav-item">📋 Student Requests</a>
      <a href="/my-bookings" class="nav-item">📊 Sessions</a>
      <a href="/profile-settings" class="nav-item">👤 Profile</a>
    </nav>
    <div class="sidebar-user">
      <div class="user-avatar"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></div>
      <div>
        <div class="user-name"><%= user.name %></div>
        <div class="user-role">Tutor</div>
      </div>
      <a href="/logout" class="logout-btn" style="margin-left: auto; color: var(--gray-400);">🚪 Logout</a>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <div class="topbar-left">
        <h1>My Schedule</h1>
        <p>Manage your sessions and track attendance</p>
      </div>
      <div class="topbar-right">
        <a href="/profile-settings" class="user-avatar" style="text-decoration:none;"><%= user.name.charAt(0) %><%= user.name.split(' ')[1]?.charAt(0) || '' %></a>
        <a href="/logout" class="btn btn-ghost btn-sm" style="margin-left: 8px;">Logout</a>
      </div>
    </header>

    <div class="page-content">
      <!-- Success/Error Messages -->
      <% if (success) { %>
        <div class="alert alert-success">
          ✅ <%= success.replace(/\+/g, ' ') %>
        </div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error">
          ❌ <%= error.replace(/\+/g, ' ') %>
        </div>
      <% } %>

      <!-- Stats Cards with Rating -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-value" id="totalSessions">-</div>
          <div class="stat-label">Total Sessions</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" id="attendedSessions">-</div>
          <div class="stat-label">Attended</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" id="missedSessions">-</div>
          <div class="stat-label">Missed</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" id="attendanceRate">-</div>
          <div class="stat-label">Attendance Rate</div>
        </div>
        <div class="stat-card rating-card">
          <div class="stat-value"><%= stats.rating %></div>
          <div class="stat-label">⭐ Rating</div>
        </div>
      </div>

      <!-- Attendance Recommendation -->
      <div id="recommendationBox" style="margin-bottom: 24px;"></div>

      <!-- Pending Attendance Section -->
      <% if (pendingAttendance && pendingAttendance.length > 0) { %>
        <div class="section-header">
          <span class="section-title">⏳ Pending Attendance</span>
          <span class="badge badge-yellow"><%= pendingAttendance.length %> sessions need marking</span>
        </div>
        <div class="booking-list">
          <% pendingAttendance.forEach(booking => { %>
            <div class="booking-item pending-card">
              <div class="booking-info">
                <h4><%= booking.subject.name %> with <%= booking.student.name %></h4>
                <div class="booking-meta">
                  <span>📅 <%= new Date(booking.date).toDateString() %></span>
                  <span>⏰ <%= booking.startTime %> – <%= booking.endTime %></span>
                  <span><%= booking.location === 'online' ? '💻 Online' : '📍 On-campus' %></span>
                </div>
                <div class="attendance-buttons">
                  <form method="POST" action="/api/attendance/<%= booking._id %>?_method=PUT" style="display: inline-block;">
                    <input type="hidden" name="attendance" value="attended">
                    <button type="submit" class="btn-attend" onclick="return confirm('Mark <%= booking.student.name %> as ATTENDED?')">
                      ✓ Mark Attended
                    </button>
                  </form>
                  <form method="POST" action="/api/attendance/<%= booking._id %>?_method=PUT" style="display: inline-block;">
                    <input type="hidden" name="attendance" value="missed">
                    <button type="submit" class="btn-miss" onclick="return confirm('Mark <%= booking.student.name %> as MISSED?')">
                      ✗ Mark Missed
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- Upcoming Sessions Section -->
      <div class="section-header">
        <span class="section-title">📅 Upcoming Sessions</span>
        <a href="/my-bookings" class="link-turquoise">View All</a>
      </div>
      <div class="booking-list">
        <% if (bookings.length === 0) { %>
          <div class="card" style="text-align:center; padding:40px;">
            <p>No upcoming sessions. Check student requests to get started!</p>
          </div>
        <% } else { %>
          <% bookings.forEach(booking => { %>
            <div class="booking-item">
              <div class="booking-info">
                <h4><%= booking.subject.name %> with <%= booking.student.name %></h4>
                <div class="booking-meta">
                  <span>📅 <%= new Date(booking.date).toDateString() %></span>
                  <span>⏰ <%= booking.startTime %> – <%= booking.endTime %></span>
                  <span><%= booking.location === 'online' ? '💻 Online' : '📍 On-campus' %></span>
                </div>
                <% if (booking.attendance === 'attended') { %>
                  <div class="attendance-badge attendance-attended" style="margin-top: 8px;">
                    ✓ Student attended
                  </div>
                <% } else if (booking.attendance === 'missed') { %>
                  <div class="attendance-badge attendance-missed" style="margin-top: 8px;">
                    ✗ Student missed
                  </div>
                <% } else if (new Date(booking.date) < new Date()) { %>
                  <div class="attendance-buttons">
                    <form method="POST" action="/api/attendance/<%= booking._id %>?_method=PUT" style="display: inline-block;">
                      <input type="hidden" name="attendance" value="attended">
                      <button type="submit" class="btn-attend" onclick="return confirm('Mark this session as ATTENDED?')">
                        ✓ Mark Attended
                      </button>
                    </form>
                    <form method="POST" action="/api/attendance/<%= booking._id %>?_method=PUT" style="display: inline-block;">
                      <input type="hidden" name="attendance" value="missed">
                      <button type="submit" class="btn-miss" onclick="return confirm('Mark this session as MISSED?')">
                        ✗ Mark Missed
                      </button>
                    </form>
                  </div>
                <% } else if (booking.attendance === 'pending') { %>
                  <div class="attendance-badge attendance-pending" style="margin-top: 8px;">
                    ⏳ Attendance pending
                  </div>
                <% } %>
              </div>
              <button class="btn btn-primary btn-sm" onclick="location.href='/my-bookings'">View Details</button>
            </div>
          <% }) %>
        <% } %>
      </div>

      <!-- Reviews & Feedback Section -->
      <div class="section-header" style="margin-top: 32px;">
        <span class="section-title">⭐ Reviews & Feedback</span>
        <span class="badge" style="background: #FBBF24; color: #92400E;"><%= stats.totalReviews %> reviews</span>
      </div>

      <div class="reviews-grid">
        <!-- Rating Summary Card -->
        <div class="card" style="text-align: center; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
          <div style="font-size: 60px; font-weight: 700;"><%= stats.rating %></div>
          <div style="font-size: 14px; margin: 5px 0;">out of 5</div>
          <div style="font-size: 24px; letter-spacing: 2px;">
            <% for(let i = 1; i <= 5; i++) { %>
              <% if(i <= Math.round(stats.rating)) { %>★<% } else { %>☆<% } %>
            <% } %>
          </div>
          <div style="font-size: 12px; margin-top: 10px; opacity: 0.8;">Based on <%= stats.totalReviews %> student reviews</div>
        </div>

        <!-- Rating Distribution Card -->
        <div class="card">
          <h4 style="margin-bottom: 15px;">Rating Distribution</h4>
          <% for(let star = 5; star >= 1; star--) { %>
            <% const count = ratingDistribution[star] || 0; %>
            <% const percentage = stats.totalReviews > 0 ? (count / stats.totalReviews) * 100 : 0; %>
            <div class="rating-distribution-bar">
              <div class="rating-label"><%= star %> ★</div>
              <div class="rating-bar-track">
                <div class="rating-bar-fill" style="width: <%= percentage %>%"></div>
              </div>
              <div class="rating-count"><%= count %></div>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Individual Reviews -->
      <% if (reviews.length > 0) { %>
        <div style="margin-top: 20px;">
          <h4 style="margin-bottom: 15px;">Recent Feedback</h4>
          <% reviews.slice(0, 5).forEach(review => { %>
            <div class="review-card">
              <div class="review-header">
                <div>
                  <span class="review-student"><%= review.student.name %></span>
                  <span class="review-date" style="margin-left: 10px;">📅 <%= new Date(review.createdAt).toDateString() %></span>
                </div>
                <div class="review-stars">
                  <% for(let i = 1; i <= 5; i++) { %>
                    <% if(i <= review.rating) { %>★<% } else { %>☆<% } %>
                  <% } %>
                </div>
              </div>
              <div class="review-comment">
                "<%= review.comment || 'No comment provided.' %>"
              </div>
              <% if (review.sentiment) { %>
                <div style="margin-top: 10px; font-size: 11px; color: var(--gray-400);">
                  Sentiment: <%= review.sentiment %>
                </div>
              <% } %>
            </div>
          <% }) %>
          <% if (reviews.length > 5) { %>
            <div style="text-align: center; margin-top: 15px;">
              <a href="/my-bookings" class="link-turquoise">View all <%= reviews.length %> reviews →</a>
            </div>
          <% } %>
        </div>
      <% } else { %>
        <div class="card no-reviews">
          <p>📝 No reviews yet. Complete sessions with students to receive feedback!</p>
        </div>
      <% } %>

      <!-- Pending Requests Link -->
      <div style="margin-top: 24px; text-align: center;">
        <a href="/student-requests" class="btn btn-primary">View Pending Requests (<%= stats.pendingRequests %>)</a>
      </div>
    </div>
  </main>
</div>

<script>
  // Load attendance analytics
  fetch(`/api/attendance-analytics/<%= user.id %>`)
    .then(res => res.json())
    .then(data => {
      document.getElementById('totalSessions').innerHTML = data.totalSessions;
      document.getElementById('attendedSessions').innerHTML = data.attendedSessions;
      document.getElementById('missedSessions').innerHTML = data.missedSessions;
      document.getElementById('attendanceRate').innerHTML = data.attendanceRate + '%';
      
      let trendIcon = '';
      if (data.noShowTrend > 30) {
        trendIcon = '⚠️';
      } else if (data.noShowTrend > 15) {
        trendIcon = '📌';
      } else {
        trendIcon = '✅';
      }
      
      document.getElementById('recommendationBox').innerHTML = `
        <div class="card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <h3 style="margin-bottom: 8px;">${trendIcon} Attendance Insights</h3>
              <p style="opacity: 0.9; font-size: 13px;">${data.recommendation}</p>
            </div>
            <div style="font-size: 40px;">📊</div>
          </div>
          <div style="margin-top: 12px; display: flex; gap: 20px; flex-wrap: wrap; font-size: 12px; opacity: 0.9;">
            <div>📈 Last 30 days: ${data.recentSessions} sessions</div>
            <div>✅ Attended: ${data.recentAttended}</div>
            <div>❌ Missed: ${data.recentMissed}</div>
            <div>📉 No-show rate: ${data.noShowTrend}%</div>
          </div>
        </div>
      `;
    })
    .catch(err => {
      console.error('Error loading attendance stats:', err);
      document.getElementById('recommendationBox').innerHTML = `
        <div class="card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
          <div style="text-align: center; padding: 20px;">
            <h3>📊 Attendance Analytics</h3>
            <p>Complete more sessions to see insights</p>
          </div>
        </div>
      `;
    });
</script>
</body>
</html>