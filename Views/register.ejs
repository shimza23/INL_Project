<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Register | SmartTutor</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/styles.css"/>
  <style>
    .register-body { background: var(--gray-50); display: flex; align-items: center; justify-content: center; min-height: 100vh; margin:0; }
    .register-wrapper { width: 100%; max-width: 550px; padding: 20px; }
    .register-card { background: var(--white); border-radius: var(--radius-lg); border: 1px solid var(--gray-200); padding: 36px 32px; box-shadow: var(--shadow-md); }
    .role-buttons { display: flex; gap: 10px; margin-bottom: 20px; }
    .role-btn { flex: 1; padding: 10px; border: 2px solid var(--gray-200); border-radius: var(--radius); background: white; cursor: pointer; font-weight: 500; font-family: var(--font); }
    .role-btn.active { border-color: var(--turquoise); background: var(--turquoise-bg); color: var(--turquoise-dark); }
    .modules-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; max-height: 200px; overflow-y: auto; padding: 10px; border: 1px solid var(--gray-200); border-radius: var(--radius-sm); }
    .module-checkbox { display: flex; align-items: center; gap: 8px; padding: 5px; }
    .error-message { background: #FEE2E2; color: #DC2626; padding: 10px; border-radius: var(--radius-sm); margin-bottom: 16px; font-size: 13px; text-align: center; }
  </style>
</head>
<body class="register-body">
<div class="register-wrapper">
  <div class="register-card">
    <div class="login-logo" style="margin-bottom:20px;">
      <div class="logo-icon">🎓</div>
      <div>
        <div style="font-size:18px;font-weight:700;">Create Account</div>
        <div style="font-size:11px;color:var(--gray-400);">Join SmartTutor today</div>
      </div>
    </div>
    
    <% if (error) { %>
      <div class="error-message"><%= error %></div>
    <% } %>
    
    <form method="POST" action="/register">
      <div class="role-buttons">
        <button type="button" class="role-btn active" onclick="setRole('student')">🎓 Student</button>
        <button type="button" class="role-btn" onclick="setRole('tutor')">👩‍🏫 Tutor</button>
      </div>
      <input type="hidden" name="role" id="roleInput" value="student">
      
      <div class="form-group">
        <label class="form-label">Full Name</label>
        <input class="form-input" type="text" name="name" required placeholder="Thabo Nkosi"/>
      </div>
      
      <div class="form-group">
        <label class="form-label">Email Address</label>
        <input class="form-input" type="email" name="email" required placeholder="name@belgiumcampus.ac.za"/>
      </div>
      
      <div class="form-group" id="studentNumberGroup">
        <label class="form-label">Student Number</label>
        <input class="form-input" type="text" name="studentNumber" placeholder="e.g., 22012345"/>
      </div>
      
      <!-- Tutor Modules Selection (hidden by default) -->
      <div class="form-group" id="tutorModulesGroup" style="display:none;">
        <label class="form-label">Modules I Can Tutor</label>
        <div class="modules-grid">
          <% subjects.forEach(subject => { %>
            <label class="module-checkbox">
              <input type="checkbox" name="tutorModules" value="<%= subject.code %>">
              <span><%= subject.code %> - <%= subject.name %></span>
            </label>
          <% }) %>
        </div>
        <small style="color: var(--gray-400);">Select all modules you are qualified to tutor</small>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Password</label>
          <input class="form-input" type="password" name="password" required placeholder="At least 6 characters"/>
        </div>
        <div class="form-group">
          <label class="form-label">Confirm Password</label>
          <input class="form-input" type="password" name="confirmPassword" required/>
        </div>
      </div>
      
      <button type="submit" class="btn btn-primary btn-full" style="margin-top:10px;">Register</button>
    </form>
    
    <p style="text-align:center; margin-top:20px; font-size:13px;">
      Already have an account? <a href="/login" style="color:var(--pink);">Login</a>
    </p>
  </div>
</div>
<script>
function setRole(role) {
  document.querySelectorAll('.role-btn').forEach(btn => btn.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('roleInput').value = role;
  
  const studentNumberGroup = document.getElementById('studentNumberGroup');
  const tutorModulesGroup = document.getElementById('tutorModulesGroup');
  
  if (role === 'student') {
    studentNumberGroup.style.display = 'block';
    tutorModulesGroup.style.display = 'none';
  } else {
    studentNumberGroup.style.display = 'none';
    tutorModulesGroup.style.display = 'block';
  }
}
</script>
</body>
</html>